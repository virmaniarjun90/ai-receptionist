# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_receptionist"

# ─── Redis (BullMQ) ───────────────────────────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT="6379"

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Options: mock | claude | openai | kimi
# mock  → no API key needed, reads knowledge base, supports full handoff demo
# claude → Anthropic (recommended for production)
# openai → OpenAI GPT
# kimi  → Moonshot
LLM_PROVIDER="mock"

ANTHROPIC_API_KEY=""           # required when LLM_PROVIDER=claude
CLAUDE_MODEL="claude-sonnet-4-6"

OPENAI_API_KEY=""              # required when LLM_PROVIDER=openai
OPENAI_MODEL="gpt-4o-mini"

KIMI_API_KEY=""                # required when LLM_PROVIDER=kimi
KIMI_MODEL="moonshot-v1-8k"

# ─── Twilio (WhatsApp) ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# The property's WhatsApp number (must include whatsapp: prefix)
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"
# Host's personal WhatsApp — receives handoff alerts (JOIN/SKIP/DONE flow)
HOST_WHATSAPP_NUMBER="whatsapp:+91XXXXXXXXXX"
# Set true in production to validate Twilio webhook signatures
TWILIO_VALIDATE_WEBHOOK="false"

# ─── App Mode ─────────────────────────────────────────────────────────────────
# demo       → Twilio sandbox; only sends WhatsApp to numbers in DEMO_ALLOWED_NUMBERS.
#              Prevents wasting the 50-message/day sandbox limit on non-opted-in numbers.
# pilot      → Real Twilio number, manual form onboarding, sends to all guests.
# production → Channel manager active, fully automated, no manual steps.
APP_MODE="demo"

# Comma-separated list of WhatsApp numbers that can receive messages in demo mode.
# These numbers must have opted in to the Twilio sandbox first by texting
# "join <word>" to the sandbox number (+1 415 523 8886).
DEMO_ALLOWED_NUMBERS="whatsapp:+91XXXXXXXXXX,whatsapp:+91YYYYYYYYYY"

# ─── Guest Onboarding ─────────────────────────────────────────────────────────
# Three modes (not mutually exclusive — all can be used together):
#
# 1. MANUAL FORM — share this URL with guests before check-in:
#       <APP_URL>/guest/register?p=<PROPERTY_ID>
#    Guest fills in name, phone, dates → reservation created → welcome WhatsApp sent.
#    APP_URL is used to build the welcome kit link inside that WhatsApp message.
#
# 2. ADMIN ENTRY — create reservations directly via:
#       POST /admin/properties/:id/reservations
#    or through the Admin UI → Properties → Reservations tab.
#    AI greets by name when guest texts first (no proactive message sent).
#
# 3. CHANNEL MANAGER SYNC — set CHANNEL_MANAGER_PROVIDER=airbnb below.
#    Reservations pulled automatically on SYNC_CRON schedule.
APP_URL="http://localhost:3000"

# ─── Channel Manager ──────────────────────────────────────────────────────────
# Options: mock | airbnb
# mock   → returns fixture data, full sync flow works without real credentials
# airbnb → requires Airbnb Partner API approval (https://www.airbnb.com/partner)
CHANNEL_MANAGER_PROVIDER="mock"

# Required when CHANNEL_MANAGER_PROVIDER=airbnb:
# Option A — access token (simplest)
AIRBNB_ACCESS_TOKEN=""
# Option B — OAuth client credentials (server-to-server apps)
AIRBNB_CLIENT_ID=""
AIRBNB_CLIENT_SECRET=""

# Cron schedule for automatic sync (default: every hour)
SYNC_CRON="0 * * * *"

# ─── Admin API ────────────────────────────────────────────────────────────────
# Protects all /admin/* endpoints via x-admin-key header.
# Leave empty for open access in local dev.
# Set a strong random string in production (e.g. openssl rand -hex 32).
ADMIN_API_KEY=""

# ─── Server ───────────────────────────────────────────────────────────────────
PORT="3000"

# ─── Privacy ──────────────────────────────────────────────────────────────────
# When true, guest phone numbers and emails are never sent to the LLM.
PII_MASKING_ENABLED="true"
