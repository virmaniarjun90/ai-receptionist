# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_receptionist?schema=public"

# ─── Redis (BullMQ) ───────────────────────────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT="6379"

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# Options: mock | openai | claude | kimi
LLM_PROVIDER="mock"

# Required when LLM_PROVIDER=openai
OPENAI_API_KEY="sk-your-openai-key"
OPENAI_MODEL="gpt-4o-mini"

# Required when LLM_PROVIDER=claude
ANTHROPIC_API_KEY="sk-ant-your-anthropic-key"
CLAUDE_MODEL="claude-sonnet-4-6"

# Required when LLM_PROVIDER=kimi
KIMI_API_KEY="sk-your-kimi-key"
KIMI_MODEL="moonshot-v1-8k"

# ─── Twilio (WhatsApp) ────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
# Must include the whatsapp: prefix
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"
# Set to false in dev to skip Twilio webhook signature validation
TWILIO_VALIDATE_WEBHOOK="false"

# ─── Channel Manager ──────────────────────────────────────────────────────────
# Options: mock | airbnb
CHANNEL_MANAGER_PROVIDER="mock"

# Required when CHANNEL_MANAGER_PROVIDER=airbnb (needs Airbnb partner approval)
AIRBNB_CLIENT_ID=""
AIRBNB_CLIENT_SECRET=""

# ─── Admin API ────────────────────────────────────────────────────────────────
# Set to protect /admin/* endpoints. Leave empty for open access in local dev.
ADMIN_API_KEY=""

# ─── Server ───────────────────────────────────────────────────────────────────
PORT="3000"

# ─── PII ──────────────────────────────────────────────────────────────────────
PII_MASKING_ENABLED="true"
