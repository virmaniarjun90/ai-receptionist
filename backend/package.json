    "axios": "^1.7.9",
    "bullmq": "^5.76.5",
    "dotenv": "^16.4.7",
    "ioredis": "^5.10.1",
    "openai": "^4.77.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
